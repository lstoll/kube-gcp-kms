# Copy to .env and fill in values.

# Path to a patched k3s binary (see k3s-args-patch.diff). Leave unset to use upstream k3s.
K3S_BINARY=./k3s

# GCP KMS symmetric encryption key
GCP_KMS_KEY=projects/PROJECT/locations/LOCATION/keyRings/RING/cryptoKeys/KEY

# GCP KMS asymmetric signing key version
GCP_JWT_KEY_VERSION=projects/PROJECT/locations/LOCATION/keyRings/RING/cryptoKeys/KEY/cryptoKeyVersions/1

# Path to GCP service account key JSON (must have cloudkms.cryptoKeyEncrypterDecrypter + cloudkms.signerVerifier)
GOOGLE_SA_KEY=gcp-sa-key.json

# Linux target arch for the VM — arm64 for Apple Silicon / VirtualBox on ARM, amd64 otherwise
GOARCH=arm64
